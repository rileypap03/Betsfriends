# Team shared password (anyone with this can access the app)
TEAM_PASSWORD=change-me-to-something-secret

# Supabase (from your Supabase project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# API-Football (from https://www.api-football.com/, free tier = 100 reqs/day)
API_FOOTBALL_KEY=your-api-football-key

# World Cup league ID and season on API-Football
# (1 = World Cup, 2026 = the tournament year)
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026
